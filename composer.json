{
    "name": "infocyph/intermix",
    "description": "A lightweight PHP DI container, invoker, serializer, and utility toolkit.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "intermix",
        "di",
        "container",
        "dependency-injection",
        "psr-11",
        "invoker",
        "serializer",
        "attributes",
        "scoped-services",
        "macro",
        "mixin",
        "cache",
        "reflection"
    ],
    "authors": [
        {
            "name": "Infocyph",
            "email": "infocyph@gmail.com"
        },
        {
            "name": "abmmhasan",
            "email": "abmmhasan@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "opis/closure": "^4.5",
        "psr/cache": "^3.0",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "infocyph/phpforge": "dev-main"
    },
    "suggest": {
        "ext-mbstring": "Recommended for development tools output formatting (Pest/Termwind)",
        "infocyph/cachelayer": "Optional cache adapters for InterMix definition cache integration (PSR-6)"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Infocyph\\InterMix\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Infocyph\\InterMix\\Tests\\": "tests/"
        },
        "exclude-from-classmap": [
            "/tests/**/*Test.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infocyph/phpforge": true,
            "pestphp/pest-plugin": true
        },
        "classmap-authoritative": true,
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
